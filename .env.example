# Leave empty when the Python API serves the built UI on the same origin.
VITE_API_BASE=

# For split deployments, point the static UI at the hosted Python API.
# VITE_API_BASE=https://weiss-play-api.example.com

# Local Vite dev proxy target. Only used by `npm run dev`.
VITE_API_PROXY=http://127.0.0.1:8765
